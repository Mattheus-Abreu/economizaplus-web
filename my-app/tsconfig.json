{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "expo-asset.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "svg.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".expo"
  ]
}